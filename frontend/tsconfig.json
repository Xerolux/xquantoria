{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": false,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "noImplicitReturns": false,
    "noImplicitThis": false,
    "noFallthroughCasesInSwitch": false,
    "noErrorTruncation": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/service-worker.ts",
    "src/components/BlockEditor/**/*",
    "src/components/CookieBannerGDPR.tsx",
    "src/components/KeyboardShortcutsModal.tsx",
    "src/components/Breadcrumb.tsx",
    "src/components/NotificationBell.tsx",
    "src/components/SEO/**/*",
    "src/components/Layout/PublicHeader.tsx",
    "src/components/Layout/PublicFooter.tsx",
    "src/components/mobile/**/*",
    "src/examples/**/*",
    "src/hooks/collaboration/**/*",
    "src/hooks/useGraphQL.ts",
    "src/hooks/usePWA.ts",
    "src/hooks/useDebouncedCallback.ts",
    "src/i18n/**/*",
    "src/pages/CheckoutPage.tsx",
    "src/pages/PaymentsPage.tsx",
    "src/pages/FormBuilderPage.tsx",
    "src/pages/SchedulePage.tsx",
    "src/pages/SettingsPage.tsx",
    "src/pages/SystemLogsPage.tsx",
    "src/pages/WebhooksPage.tsx",
    "src/pages/AnalyticsDashboardPage.tsx",
    "src/pages/public/BlogPage.tsx",
    "src/pages/public/HomePage.tsx",
    "src/pages/ProfilePage.tsx",
    "src/pages/public/BlogPage.tsx",
    "src/pages/public/HomePage.tsx",
    "src/pages/BackupsPage.tsx",
    "src/pages/DownloadsPage.tsx",
    "src/pages/EmailVerificationPage.tsx",
    "src/pages/FormBuilderPage.tsx",
    "src/pages/MediaPage.tsx",
    "src/pages/MenuBuilderPage.tsx",
    "src/pages/NewslettersPage.tsx",
    "src/pages/PostSharingPage.tsx",
    "src/pages/RedirectsPage.tsx",
    "src/pages/RSSFeedPage.tsx",
    "src/pages/SettingsPage.tsx",
    "src/pages/SystemLogsPage.tsx",
    "src/pages/WebhooksPage.tsx",
    "src/pages/CheckoutPage.tsx",
    "src/pages/PaymentsPage.tsx",
    "src/store/blockEditorStore.ts",
    "src/types/blocks.ts"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
